<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ListView?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<BorderPane prefHeight="980.0" prefWidth="1500.0" stylesheets="@styles/back-office.css" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="pi.controllers.ImprevusCasreelController.ImprevusBackController">
  <top>
    <VBox styleClass="top-shell">
      <padding><Insets bottom="0.0" left="28.0" right="28.0" top="22.0" /></padding>
      <children>
        <HBox alignment="CENTER_LEFT" styleClass="top-nav">
          <children>
            <HBox alignment="CENTER_LEFT" spacing="12.0">
              <children>
                <Label styleClass="brand-badge" text="DS" />
                <Label styleClass="brand-mark" text="Decide$" />
              </children>
            </HBox>
            <Region HBox.hgrow="ALWAYS" />
            <Label styleClass="workspace-title" text="Unexpected Events &amp; Reals Cases Back Office" />
            <Region HBox.hgrow="ALWAYS" />
            <Button onAction="#handleGoFront" styleClass="header-start-btn" text="Go to Front" />
          </children>
        </HBox>
      </children>
    </VBox>
  </top>
  <center>
    <ScrollPane fitToWidth="true" hbarPolicy="NEVER" styleClass="page-scroll" vbarPolicy="AS_NEEDED">
      <content>
        <VBox spacing="26.0" styleClass="back-root">
          <padding>
            <Insets bottom="28.0" left="30.0" right="30.0" top="24.0" />
          </padding>
          <children>
            <VBox spacing="8.0" styleClass="hero-card">
              <children>
                <Label styleClass="page-title" text="Back Office Management" />
                <Label styleClass="page-subtitle" text="New unexpected events are created with a default budget of 0. The displayed event budget is the total of all linked real cases." wrapText="true" />
              </children>
            </VBox>
            <HBox alignment="TOP_CENTER" spacing="20.0">
              <children>
                <VBox prefWidth="470.0" spacing="18.0">
                  <children>
                    <VBox spacing="14.0" styleClass="panel-card">
                      <padding>
                        <Insets bottom="18.0" left="18.0" right="18.0" top="18.0" />
                      </padding>
                      <children>
                        <Label styleClass="panel-step" text="STEP 1" />
                        <Label styleClass="panel-title" text="Manage Unexpected Events" />
                        <Label styleClass="page-subtitle" text="Only the generic title is managed here. No manual budget entry." wrapText="true" />
                        <TextField fx:id="imprevuTitreField" promptText="Titre generique de l'imprevu" />
                        <ComboBox fx:id="imprevuTypeComboBox" promptText="Type" />
                        <HBox spacing="10.0">
                          <children>
                            <Button onAction="#handleSaveImprevu" styleClass="action-primary" text="Ajouter / Modifier" HBox.hgrow="ALWAYS" />
                            <Button onAction="#handleDeleteImprevu" styleClass="action-danger" text="Supprimer" HBox.hgrow="ALWAYS" />
                          </children>
                        </HBox>
                        <ListView fx:id="imprevusListView" prefHeight="560.0" />
                      </children>
                    </VBox>
                  </children>
                </VBox>
                <VBox spacing="18.0" HBox.hgrow="ALWAYS">
                  <children>
                    <VBox spacing="14.0" styleClass="panel-card">
                      <padding>
                        <Insets bottom="18.0" left="18.0" right="18.0" top="18.0" />
                      </padding>
                      <children>
                        <Label styleClass="panel-step" text="STEP 2" />
                        <Label styleClass="panel-title" text="Review Real Cases" />
                        <Label styleClass="page-subtitle" text="This area is only for case management and decision making. No add, modify, delete, and no table." wrapText="true" />
                        <Label fx:id="systemStatusLabel" styleClass="system-banner" text="System status: notif in-app active | mail/maps selon .env" wrapText="true" />
                        <ListView fx:id="casListView" prefHeight="280.0" />
                        <Separator />
                         <Label fx:id="casTitreLabel" styleClass="detail-title" text="Select a case" />
                         <Label fx:id="casMetaLabel" styleClass="page-subtitle" text="No case selected" wrapText="true" />
                         <Label fx:id="casEtatLabel" styleClass="status-pill" text="-" />
                         <Label fx:id="casPaymentLabel" styleClass="page-subtitle" text="Payment method: -" wrapText="true" />
                         <Label fx:id="casAuditLabel" styleClass="page-subtitle" text="Processed by: -" wrapText="true" />
                         <Label fx:id="casAiSuggestionLabel" styleClass="page-subtitle" text="AI suggestion: -" wrapText="true" />
                         <Label fx:id="casNotificationLabel" styleClass="page-subtitle" text="Notification: -" wrapText="true" />
                         <TextArea fx:id="casDescriptionArea" editable="false" prefHeight="130.0" promptText="Description du cas reel" wrapText="true" />
                         <TextField fx:id="raisonRefusField" promptText="Raison de refus" />
                         <TextArea fx:id="adminNoteArea" prefHeight="90.0" promptText="Note admin visible dans l'historique et dans le mail" wrapText="true" />
                         <HBox spacing="10.0">
                          <children>
                            <Button onAction="#handleAcceptCas" styleClass="action-validate" text="Valider" HBox.hgrow="ALWAYS" />
                            <Button onAction="#handleRefuseCas" styleClass="action-refuse" text="Refuser" HBox.hgrow="ALWAYS" />
                          </children>
                        </HBox>
                      </children>
                    </VBox>
                  </children>
                </VBox>
              </children>
            </HBox>
          </children>
        </VBox>
      </content>
    </ScrollPane>
  </center>
</BorderPane>
