<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<AnchorPane styleClass="content-wrapper"
            xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="pi.controllers.UserTransactionController.UsersManagementController">
    <children>
        <ScrollPane fitToHeight="true" fitToWidth="true" hbarPolicy="NEVER" pannable="true" styleClass="content-scroll" vbarPolicy="AS_NEEDED"
                    AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">
            <content>
                <VBox spacing="10.0" styleClass="content-root">
                    <children>
                        <HBox alignment="TOP_LEFT" spacing="6.0">
                            <children>
                                <VBox spacing="4.0">
                                    <children>
                                        <Label fx:id="headerLabel" styleClass="admin-title" text="Users" />
                                        <Label fx:id="headerSubtitle" styleClass="admin-subtitle" text="Manage admin and user accounts from one workspace." />
                                    </children>
                                </VBox>
                                <Region HBox.hgrow="ALWAYS" />
                                <VBox alignment="TOP_RIGHT" spacing="10.0">
                                    <children>
                                        <HBox alignment="CENTER_RIGHT" spacing="10.0">
                                            <children>
                                                <StackPane>
                                                    <children>
                                                        <Button mnemonicParsing="false" styleClass="utility-icon-btn" text="&#x1F514;" />
                                                        <Label styleClass="notify-badge" text="3" StackPane.alignment="TOP_RIGHT" />
                                                    </children>
                                                </StackPane>
                                                <StackPane styleClass="header-avatar">
                                                    <children>
                                                        <Label styleClass="header-avatar-text" text="A" />
                                                    </children>
                                                </StackPane>
                                            </children>
                                        </HBox>
                                        <HBox alignment="CENTER_RIGHT" spacing="10.0" styleClass="top-action-buttons">
                                            <children>
                                                <Button fx:id="myProfileButton" mnemonicParsing="false" onAction="#handleMyProfile" styleClass="header-button" text="My profile">
                                                    <graphic>
                                                        <Label styleClass="button-icon" text="&#x1F464;" />
                                                    </graphic>
                                                </Button>
                                                <Button fx:id="editProfileButton" mnemonicParsing="false" onAction="#handleEditMyProfile" styleClass="header-button" text="Edit my profile">
                                                    <graphic>
                                                        <Label styleClass="button-icon" text="&#x270E;" />
                                                    </graphic>
                                                </Button>
                                                <Button fx:id="addUserButton" mnemonicParsing="false" onAction="#handleAddUser" styleClass="primary-button" text="Add user">
                                                    <graphic>
                                                        <Label styleClass="button-icon primary-button-icon" text="+" />
                                                    </graphic>
                                                </Button>
                                            </children>
                                        </HBox>
                                    </children>
                                </VBox>
                            </children>
                        </HBox>

                        <StackPane maxWidth="Infinity" VBox.vgrow="ALWAYS">
                            <children>
                                <VBox spacing="12.0" styleClass="content-stack">
                                    <children>
                                        <HBox spacing="12.0">
                                            <children>
                                                <VBox fx:id="searchCard" spacing="10.0" styleClass="card card-narrow">
                                                    <children>
                                                        <HBox alignment="CENTER_LEFT" spacing="8.0">
                                                            <children>
                                                                <StackPane styleClass="section-icon"><children><Label styleClass="section-icon-text" text="&#x1F50D;" /></children></StackPane>
                                                                <Label styleClass="card-title" text="Search &amp; filters" />
                                                            </children>
                                                        </HBox>

                                                        <VBox spacing="10.0">
                                                            <children>
                                                                <VBox spacing="6.0">
                                                                    <children>
                                                                        <Label styleClass="filter-label" text="Search" />
                                                                        <TextField fx:id="searchField" promptText="Search by name, email, role..." styleClass="filter-field" />
                                                                    </children>
                                                                </VBox>

                                                                <VBox spacing="6.0">
                                                                    <children>
                                                                        <Label styleClass="filter-label" text="Role" />
                                                                        <ComboBox fx:id="roleFilterCombo" prefWidth="220.0" styleClass="filter-field" />
                                                                    </children>
                                                                </VBox>

                                                                <VBox spacing="6.0">
                                                                    <children>
                                                                        <Label styleClass="filter-label" text="Sort by" />
                                                                        <ComboBox fx:id="sortFilterCombo" prefWidth="220.0" styleClass="filter-field" />
                                                                    </children>
                                                                </VBox>

                                                                <VBox spacing="6.0">
                                                                    <children>
                                                                        <Label styleClass="filter-label" text="Order" />
                                                                        <ComboBox fx:id="orderFilterCombo" prefWidth="220.0" styleClass="filter-field" />
                                                                    </children>
                                                                </VBox>

                                                                <HBox alignment="CENTER_LEFT" spacing="10.0">
                                                                    <children>
                                                                        <Button fx:id="resetFiltersButton" mnemonicParsing="false" onAction="#handleResetFilters" styleClass="reset-button" text="Reset" />
                                                                        <Region HBox.hgrow="ALWAYS" />
                                                                        <Button fx:id="applyFiltersButton" mnemonicParsing="false" onAction="#handleApplyFilters" styleClass="apply-button" text="Apply" />
                                                                    </children>
                                                                </HBox>
                                                            </children>
                                                        </VBox>
                                                    </children>
                                                </VBox>

                                                <VBox fx:id="usersCard" spacing="10.0" styleClass="card" HBox.hgrow="ALWAYS">
                                                    <children>
                                                        <HBox alignment="CENTER_LEFT" spacing="8.0">
                                                            <children>
                                                                <StackPane styleClass="section-icon"><children><Label styleClass="section-icon-text" text="&#x1F465;" /></children></StackPane>
                                                                <Label styleClass="card-title" text="Users (double-click Name/Email to edit)" />
                                                                <Region HBox.hgrow="ALWAYS" />
                                                                <Label styleClass="section-more" text="&#x22EF;" />
                                                            </children>
                                                        </HBox>
                                                        <TableView fx:id="usersTable" editable="true" prefHeight="470.0" styleClass="table-list users-table" VBox.vgrow="ALWAYS">
                                                            <columns>
                                                                <TableColumn fx:id="avatarColumn" prefWidth="82.0" text="AVATAR" />
                                                                <TableColumn fx:id="nameColumn" prefWidth="235.0" text="NAME" />
                                                                <TableColumn fx:id="emailColumn" prefWidth="300.0" text="EMAIL" />
                                                                <TableColumn fx:id="roleColumn" prefWidth="150.0" text="ROLE" />
                                                                <TableColumn fx:id="balanceColumn" prefWidth="170.0" text="BALANCE" />
                                                                <TableColumn fx:id="actionsColumn" prefWidth="190.0" text="ACTIONS" />
                                                            </columns>
                                                        </TableView>
                                                    </children>
                                                </VBox>
                                            </children>
                                        </HBox>

                                        <HBox alignment="CENTER_LEFT" styleClass="results-footer">
                                            <children>
                                                <Label fx:id="resultsTextLabel" styleClass="results-text" text="Showing 0 user(s)" />
                                                <Region HBox.hgrow="ALWAYS" />
                                                <HBox spacing="6.0">
                                                    <children>
                                                        <Button mnemonicParsing="false" styleClass="pager-btn pager-btn-ghost" text="&#x2039;" />
                                                        <Button mnemonicParsing="false" styleClass="pager-btn pager-btn-active" text="1" />
                                                        <Button mnemonicParsing="false" styleClass="pager-btn pager-btn-ghost" text="&#x203A;" />
                                                    </children>
                                                </HBox>
                                            </children>
                                        </HBox>
                                    </children>
                                </VBox>
                            </children>
                        </StackPane>
                    </children>
                    <padding>
                        <Insets bottom="14.0" left="14.0" right="14.0" top="10.0" />
                    </padding>
                </VBox>
            </content>
        </ScrollPane>
    </children>
</AnchorPane>

