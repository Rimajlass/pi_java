<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Hyperlink?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Pane?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<AnchorPane prefHeight="780.0" prefWidth="1460.0"
            styleClass="sign-up-root"
            xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="pi.controllers.UserTransactionController.SignUpController">
    <children>
        <ScrollPane fitToWidth="true"
                    hbarPolicy="NEVER"
                    pannable="true"
                    styleClass="sign-up-scroll"
                    AnchorPane.topAnchor="0.0"
                    AnchorPane.bottomAnchor="0.0"
                    AnchorPane.leftAnchor="0.0"
                    AnchorPane.rightAnchor="0.0">
            <content>
                <StackPane prefWidth="1460.0" styleClass="sign-up-scroll-content">
                    <children>
                        <ImageView fx:id="backgroundImageView" fitHeight="980.0" fitWidth="1460.0" preserveRatio="false">
                            <image>
                                <Image url="@../images/a2.jpg" />
                            </image>
                        </ImageView>
                        <Pane styleClass="sign-up-overlay" />

                        <HBox alignment="CENTER">
                            <children>
                                <StackPane HBox.hgrow="ALWAYS">
                                    <children>
                                        <VBox fx:id="heroContentBox" alignment="CENTER_LEFT" maxWidth="500.0" spacing="20.0" translateX="-150.0" translateY="36.0">
                                            <children>
                                                <Label styleClass="brand-mark" text="DECIDE • FINANCE WORKSPACE" />
                                                <VBox spacing="4.0">
                                                    <children>
                                                        <Label styleClass="hero-title" text="Join us and secure" />
                                                        <HBox spacing="8.0">
                                                            <children>
                                                                <Label styleClass="hero-title" text="your" />
                                                                <Label fx:id="heroAccentLabel" styleClass="hero-title-accent" text="financial future" />
                                                            </children>
                                                        </HBox>
                                                    </children>
                                                </VBox>
                                                <Region maxWidth="130.0" minHeight="3.0" prefHeight="3.0" styleClass="hero-line" />
                                                <Label maxWidth="420.0"
                                                       styleClass="hero-subtitle"
                                                       text="Create your account to manage assets, monitor performance, and access your secure finance workspace."
                                                       wrapText="true" />
                                            </children>
                                        </VBox>
                                    </children>
                                </StackPane>

                                <StackPane maxWidth="470.0" minWidth="470.0" prefWidth="470.0">
                                    <children>
                                        <VBox fx:id="signUpCardBox" maxWidth="392.0" spacing="16.0" styleClass="sign-up-card" translateX="-18.0" translateY="28.0">
                                            <padding>
                                                <Insets top="26.0" right="28.0" bottom="26.0" left="28.0" />
                                            </padding>
                                            <children>
                                                <Label styleClass="card-title" text="Sign Up" />
                                                <Label styleClass="card-subtitle" text="Create your secure account" />
                                                <Label fx:id="feedbackLabel"
                                                       maxWidth="Infinity"
                                                       styleClass="feedback-label"
                                                       text="Create your account to access the secure workspace."
                                                       wrapText="true" />

                                                <GridPane hgap="14.0" vgap="12.0">
                                                    <children>
                                                        <VBox spacing="6.0" GridPane.columnIndex="0" GridPane.rowIndex="0">
                                                            <children>
                                                                <Label styleClass="field-label" text="FULL NAME" />
                                                                <TextField fx:id="fullNameField" promptText="Full name" styleClass="sign-up-field" />
                                                            </children>
                                                        </VBox>
                                                        <VBox spacing="6.0" GridPane.columnIndex="1" GridPane.rowIndex="0">
                                                            <children>
                                                                <Label styleClass="field-label" text="EMAIL" />
                                                                <TextField fx:id="emailField" promptText="Email" styleClass="sign-up-field" />
                                                            </children>
                                                        </VBox>
                                                        <VBox spacing="6.0" GridPane.columnIndex="0" GridPane.rowIndex="1">
                                                            <children>
                                                                <Label styleClass="field-label" text="PASSWORD" />
                                                                <PasswordField fx:id="passwordField" promptText="Password" styleClass="sign-up-field" />
                                                                <Label styleClass="helper-text"
                                                                       text="At least 8 characters, with uppercase, lowercase and a number."
                                                                       wrapText="true" />
                                                            </children>
                                                        </VBox>
                                                        <VBox spacing="6.0" GridPane.columnIndex="1" GridPane.rowIndex="1">
                                                            <children>
                                                                <Label styleClass="field-label" text="CONFIRM PASSWORD" />
                                                                <PasswordField fx:id="confirmPasswordField" promptText="Confirm password" styleClass="sign-up-field" />
                                                            </children>
                                                        </VBox>
                                                        <VBox spacing="6.0" GridPane.columnIndex="0" GridPane.rowIndex="2">
                                                            <children>
                                                                <Label styleClass="field-label" text="ROLE" />
                                                                <ComboBox fx:id="roleComboBox" prefWidth="170.0" styleClass="sign-up-combo" />
                                                            </children>
                                                        </VBox>
                                                        <VBox spacing="6.0" GridPane.columnIndex="1" GridPane.rowIndex="2">
                                                            <children>
                                                                <Label styleClass="field-label" text="INITIAL BALANCE" />
                                                                <TextField fx:id="balanceField" promptText="0" styleClass="sign-up-field" />
                                                            </children>
                                                        </VBox>
                                                    </children>
                                                </GridPane>

                                                <VBox spacing="8.0" styleClass="section-box">
                                                    <padding>
                                                        <Insets top="10.0" right="10.0" bottom="10.0" left="10.0" />
                                                    </padding>
                                                    <children>
                                                        <Label styleClass="field-label" text="ANTI-ROBOT VERIFICATION" />
                                                        <Label styleClass="helper-text" text="To continue, type the characters you see in the picture." />
                                                        <Label styleClass="captcha-box" text="Q  F  D  G" />
                                                        <TextField fx:id="captchaField" promptText="TYPE CAPTCHA CODE" styleClass="sign-up-field" />
                                                    </children>
                                                </VBox>

                                                <VBox spacing="8.0" styleClass="section-box">
                                                    <padding>
                                                        <Insets top="10.0" right="10.0" bottom="10.0" left="10.0" />
                                                    </padding>
                                                    <children>
                                                        <Label styleClass="field-label" text="BIOMETRIC OPTIONS (OPTIONAL)" />
                                                        <Label styleClass="helper-text" text="You can enable face camera auth, passkey/QR auth, or both." />
                                                        <Button fx:id="faceIdButton" mnemonicParsing="false" onAction="#handleEnableFaceCamera" styleClass="secondary-button" text="Enable Face ID on this device" />
                                                        <Button fx:id="passkeyButton" mnemonicParsing="false" onAction="#handleEnablePasskeyQr" styleClass="secondary-button" text="Enable Passkey (QR)" />
                                                    </children>
                                                </VBox>

                                                <VBox spacing="8.0" styleClass="section-box">
                                                    <padding>
                                                        <Insets top="10.0" right="10.0" bottom="10.0" left="10.0" />
                                                    </padding>
                                                    <children>
                                                        <Label styleClass="field-label" text="CAMERA PREVIEW (OPTIONAL)" />
                                                        <Pane fx:id="cameraPreviewPane" prefHeight="68.0" styleClass="camera-box" />
                                                        <HBox spacing="6.0">
                                                            <children>
                                                                <Button fx:id="openCameraButton" mnemonicParsing="false" onAction="#handleOpenCamera" styleClass="mini-button" text="Open camera" />
                                                                <Button fx:id="captureCameraButton" mnemonicParsing="false" onAction="#handleCaptureAndRegister" styleClass="mini-button" text="Capture and register" />
                                                                <Button fx:id="stopCameraButton" mnemonicParsing="false" onAction="#handleStopCamera" styleClass="mini-button" text="Stop camera" />
                                                            </children>
                                                        </HBox>
                                                    </children>
                                                </VBox>

                                                <Button fx:id="registerButton" maxWidth="Infinity" mnemonicParsing="false" onAction="#handleRegister" styleClass="primary-button" text="CREATE ACCOUNT" />

                                                <HBox alignment="CENTER" spacing="4.0">
                                                    <children>
                                                        <Label styleClass="footer-text" text="Already have an account?" />
                                                        <Hyperlink fx:id="signInLink" onAction="#handleBackToLogin" styleClass="inline-link" text="Sign in" />
                                                    </children>
                                                </HBox>
                                            </children>
                                        </VBox>
                                    </children>
                                </StackPane>
                            </children>
                        </HBox>
                    </children>
                </StackPane>
            </content>
        </ScrollPane>
    </children>
</AnchorPane>
