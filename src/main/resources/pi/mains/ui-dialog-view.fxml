<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<StackPane fx:id="overlayRoot" styleClass="dialog-overlay" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="pi.tools.UiDialogController">
    <children>
        <VBox fx:id="dialogCard" maxWidth="460.0" minWidth="420.0" spacing="12.0" styleClass="dialog-root">
            <children>
                <HBox alignment="CENTER_LEFT" spacing="10.0">
                    <children>
                        <Label fx:id="iconLabel" styleClass="dialog-icon dialog-icon-info" text="i" />
                        <Label fx:id="headingLabel" styleClass="dialog-heading" text="Message" />
                        <Region HBox.hgrow="ALWAYS" />
                        <Button fx:id="closeButton" mnemonicParsing="false" styleClass="dialog-close-button" text="&#x2715;" />
                    </children>
                </HBox>
                <Label fx:id="messageLabel" styleClass="dialog-body" text="Details..." wrapText="true" />
                <VBox fx:id="hintBox" managed="false" spacing="0.0" styleClass="dialog-hint-box" visible="false">
                    <children>
                        <Label fx:id="hintLabel" styleClass="dialog-hint-text" text="Veuillez saisir une valeur valide." wrapText="true" />
                    </children>
                    <padding>
                        <Insets bottom="10.0" left="10.0" right="10.0" top="10.0" />
                    </padding>
                </VBox>
                <HBox fx:id="actionsBox" alignment="CENTER_RIGHT" spacing="8.0">
                    <children>
                        <Button fx:id="cancelButton" managed="false" mnemonicParsing="false" styleClass="dialog-cancel-button" text="Cancel" visible="false" />
                        <Button fx:id="okButton" mnemonicParsing="false" styleClass="dialog-ok-button" text="OK" />
                    </children>
                    <padding>
                        <Insets top="4.0" />
                    </padding>
                </HBox>
            </children>
            <padding>
                <Insets bottom="16.0" left="16.0" right="16.0" top="16.0" />
            </padding>
        </VBox>
    </children>
</StackPane>
