<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<VBox alignment="TOP_LEFT" prefHeight="280.0" prefWidth="500.0" spacing="14.0" styleClass="forgot-root" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="pi.controllers.UserTransactionController.ForgotPasswordController">
    <padding>
        <Insets bottom="24.0" left="24.0" right="24.0" top="24.0" />
    </padding>
    <children>
        <Label styleClass="forgot-title" text="R&#233;initialiser le mot de passe" />
        <Label styleClass="forgot-description" text="Entrez votre adresse email pour recevoir un lien de r&#233;initialisation." wrapText="true" />

        <VBox spacing="8.0">
            <children>
                <Label styleClass="forgot-label" text="Adresse email" />
                <TextField fx:id="emailField" promptText="name@exemple.com" styleClass="forgot-field" />
            </children>
        </VBox>

        <Label fx:id="feedbackLabel" maxWidth="Infinity" styleClass="forgot-feedback" text="" visible="false" wrapText="true" />

        <Region VBox.vgrow="ALWAYS" />

        <HBox alignment="CENTER_RIGHT" spacing="10.0">
            <children>
                <Button mnemonicParsing="false" onAction="#handleCancel" styleClass="cancel-button" text="Annuler" />
                <Button mnemonicParsing="false" onAction="#handleSend" styleClass="send-button" text="Envoyer" />
            </children>
        </HBox>
    </children>
</VBox>
