<AnchorPane prefHeight="780.0" prefWidth="1460.0" styleClass="admin-root" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="pi.controllers.UserTransactionController.TransactionsManagementController">
