                                        <VBox spacing="8.0">
                                            <children>
                                                <Label styleClass="field-label" text="User" />
                                                <ComboBox fx:id="formUserCombo" maxWidth="1.7976931348623157E308" styleClass="filter-field" />
                                            </children>
                                        </VBox>
                                        <HBox spacing="10.0">
                                            <children>
                                                <VBox spacing="4.0" HBox.hgrow="ALWAYS">
                                                    <children>
                                                        <Label styleClass="field-label" text="Type" />
                                                        <ComboBox fx:id="formTypeCombo" styleClass="filter-field" />
                                                    </children>
                                                </VBox>
                                                <VBox spacing="4.0" HBox.hgrow="ALWAYS">
                                                    <children>
                                                        <Label styleClass="field-label" text="Amount" />
