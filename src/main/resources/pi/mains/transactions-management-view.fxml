                                                    <children>
                                                        <Label styleClass="field-label" text="Description" />
                                                        <TextArea fx:id="formDescriptionArea" prefRowCount="2" styleClass="filter-field" wrapText="true" />
                                                    </children>
                                                </VBox>
                                            </children>
