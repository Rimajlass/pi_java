                                                </VBox>
                                                <VBox spacing="4.0" prefWidth="160.0">
                                                    <children>
                                                        <Label styleClass="field-label" text="Type" />
                                                        <ComboBox fx:id="filterTypeCombo" prefWidth="160.0" styleClass="filter-field" />
                                                    </children>
                                                </VBox>
                                                <VBox spacing="4.0">
                                                    <children>
                                                        <Label styleClass="field-label" text="Date from" />
                                                        <DatePicker fx:id="filterDateFrom" styleClass="filter-field" />
