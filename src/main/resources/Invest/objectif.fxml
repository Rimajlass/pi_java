<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import java.net.URL?>

<ScrollPane fitToWidth="true" styleClass="page-scroll" prefWidth="900" prefHeight="650"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="pi.controllers.InvestissementController.ObjectifController">
    <stylesheets>
        <URL value="@admin-style.css"/>
    </stylesheets>

    <VBox styleClass="page-root" spacing="0">

        <HBox styleClass="top-nav" alignment="CENTER_LEFT" spacing="16">
            <Label text="Mes Objectifs" styleClass="brand-mark"/>
            <HBox alignment="CENTER_RIGHT" HBox.hgrow="ALWAYS">
                <Button text="Créer un objectif" onAction="#goToCreate" styleClass="cyan-pill-button"/>
            </HBox>
        </HBox>

        <VBox styleClass="content-shell">

            <Label text="OBJECTIFS" styleClass="section-tag"/>
            <Label text="Suivi des Objectifs" styleClass="section-title"/>

            <TextField fx:id="objectifSearch" promptText="Rechercher par nom..." styleClass="text-field" maxWidth="300"/>

            <TableView fx:id="objectifTable" styleClass="history-table" prefHeight="400" maxWidth="1.7976931348623157E308">
                <columns>
                    <TableColumn fx:id="colName" text="Nom" prefWidth="150"/>
                    <TableColumn fx:id="colInitial" text="Montant initial" prefWidth="130"/>
                    <TableColumn fx:id="colTarget" text="Objectif" prefWidth="130"/>
                    <TableColumn fx:id="colCurrent" text="Valeur actuelle" prefWidth="130"/>
                    <TableColumn fx:id="colCompleted" text="Statut" prefWidth="100"/>
                    <TableColumn fx:id="colModify" text="Modifier" prefWidth="100"/>
                    <TableColumn fx:id="colDelete" text="Supprimer" prefWidth="100"/>
                </columns>
            </TableView>

        </VBox>
    </VBox>
</ScrollPane>
