<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<VBox prefHeight="460.0" prefWidth="520.0" styleClass="dialog-root" stylesheets="@../../../styles/RevenueExpenseFRONT/salary-expense.css" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="pi.controllers.ExpenseRevenueController.UPDATE.ExpenseEditController">
    <children>
        <Label styleClass="dialog-title" text="Modify Expense" />
        <Label styleClass="dialog-subtitle" text="Update the selected expense and save the new values." />
        <GridPane hgap="12.0" vgap="14.0">
            <children>
                <Label styleClass="field-label" text="Amount (TND)" GridPane.columnIndex="0" GridPane.rowIndex="0" />
                <TextField fx:id="amountField" promptText="0.00" GridPane.columnIndex="0" GridPane.rowIndex="1" />
                <Label styleClass="field-label" text="Category" GridPane.columnIndex="0" GridPane.rowIndex="2" />
                <ComboBox fx:id="categoryComboBox" prefWidth="320.0" GridPane.columnIndex="0" GridPane.rowIndex="3" />
                <Label styleClass="field-label" text="Expense date" GridPane.columnIndex="0" GridPane.rowIndex="4" />
                <DatePicker fx:id="expenseDatePicker" prefWidth="320.0" GridPane.columnIndex="0" GridPane.rowIndex="5" />
                <Label styleClass="field-label" text="Linked revenue" GridPane.columnIndex="0" GridPane.rowIndex="6" />
                <ComboBox fx:id="revenueComboBox" prefWidth="320.0" GridPane.columnIndex="0" GridPane.rowIndex="7" />
                <Label styleClass="field-label" text="Description" GridPane.columnIndex="0" GridPane.rowIndex="8" />
                <TextArea fx:id="descriptionArea" prefHeight="110.0" wrapText="true" GridPane.columnIndex="0" GridPane.rowIndex="9" />
            </children>
        </GridPane>
        <Region VBox.vgrow="ALWAYS" />
        <HBox alignment="CENTER_RIGHT" spacing="12.0">
            <children>
                <Button mnemonicParsing="false" onAction="#handleCancel" styleClass="dialog-cancel-button" text="Cancel" />
                <Button mnemonicParsing="false" onAction="#handleSave" styleClass="action-button-primary" text="Save changes" />
            </children>
        </HBox>
    </children>
    <padding>
        <Insets bottom="24.0" left="24.0" right="24.0" top="24.0" />
    </padding>
</VBox>
